MONGODB_URI=mongodb://admin:CHANGE_ME@mongo:27017/apa-db?authSource=admin
PORT=3000
JWT_SECRET=CHANGE_ME_LONG_RANDOM_SECRET

# For browser access through Caddy, prefer same-origin proxy path.
VITE_API_BASE_URL=/api

# CORS list used by backend, comma-separated.
# Examples:
# CORS_ALLOWED_ORIGINS=http://192.168.100.67:8080,https://app.example.com
CORS_ALLOWED_ORIGINS=

# Optional, only if your backend Playwright flows need these:
APA_BASE_URL=
APA_USERNAME=
APA_PASSWORD=
